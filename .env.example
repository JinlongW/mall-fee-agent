# =============================================================
# AI 模型 API Keys（至少配置一个）
# =============================================================

# Claude（合同解析用，准确率最高）
ANTHROPIC_API_KEY=sk-ant-xxx

# DeepSeek（查询/简单任务用，便宜快速）
DEEPSEEK_API_KEY=sk-xxx

# OpenAI（可选，用于兼容模式）
OPENAI_API_KEY=sk-xxx

# =============================================================
# 数据库
# =============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mall_fee_agent

# =============================================================
# Redis（任务队列）
# =============================================================
REDIS_URL=redis://localhost:6379

# =============================================================
# 应用配置
# =============================================================
API_PORT=3000
WEB_PORT=5173
NODE_ENV=development

# =============================================================
# 业务配置
# =============================================================
# 合同解析置信度阈值（低于此值需人工审核）
CONFIDENCE_THRESHOLD=0.8
